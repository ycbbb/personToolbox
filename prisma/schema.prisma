// PersonToolbox — Login-only foundation
// Based on vshop tech stack, simplified to auth-only models.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── User & Auth ────────────────────────────────────────

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String?
  role         UserRole   @default(CUSTOMER)
  status       UserStatus @default(PENDING)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  staffProfile StaffProfile?
  sessions     Session[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model StaffProfile {
  id             String         @id @default(cuid())
  userId         String         @unique
  user           User           @relation(fields: [userId], references: [id])
  displayName    String
  backofficeRole BackofficeRole
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

/// DB-driven RBAC: which Permission each BackofficeRole is granted.
model RolePermission {
  id         String         @id @default(cuid())
  role       BackofficeRole
  permission String
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([role, permission])
  @@index([role])
}

// ─── Enums ──────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  STAFF
  SYSTEM
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum BackofficeRole {
  REVIEW_ADMIN
  SALES_OPS
  WAREHOUSE
  FINANCE
  PRICING_ADMIN
  SYSTEM_ADMIN
  OPS_ADMIN
}
