{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NEXTAUTH_SECRET",
        "NEXTAUTH_SECRET_ADMIN",
        "NEXTAUTH_SECRET_FRONTEND"
      ]
    },
    "dev": {
      "persistent": true,
      "cache": false,
      "env": [
        "NEXTAUTH_SECRET",
        "NEXTAUTH_SECRET_ADMIN",
        "NEXTAUTH_SECRET_FRONTEND"
      ]
    },
    "start": {
      "persistent": true,
      "cache": false,
      "env": [
        "NEXTAUTH_SECRET",
        "NEXTAUTH_SECRET_ADMIN",
        "NEXTAUTH_SECRET_FRONTEND"
      ]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "lint": {}
  }
}
